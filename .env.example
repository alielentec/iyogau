# Copy this file to .env.local for local development.
# Do not commit .env.local or real secrets.

# Google OAuth web client credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Must exactly match an authorized redirect URI on the Google OAuth client.
# Local development:
GOOGLE_REDIRECT_URI=http://localhost:4177/api/auth/google/callback/

# Optional Google Calendar sync for the owner dashboard.
# If omitted, the owner dashboard stays local-only and shows Calendar sync as not configured.
# These can reuse the same Google OAuth web client as sign-in, but the redirect URI below
# must also be authorized in Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4177/api/owner/google-calendar/callback/
IYOGAU_GOOGLE_CALENDAR_ID=primary
IYOGAU_GOOGLE_CALENDAR_NAME=iYogaU Calendar
IYOGAU_GOOGLE_CALENDAR_TOKEN_SECRET=replace-with-at-least-32-random-characters

# Apple Sign in credentials.
# APPLE_CLIENT_ID is the Services ID, for example com.example.web.
# Use either APPLE_CLIENT_SECRET or the Team/Key/private-key values below.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:4177/api/auth/apple/callback/

# Kakao Login REST API credentials.
# KAKAO_CLIENT_ID is the Kakao REST API key. KAKAO_CLIENT_SECRET is optional
# unless client-secret validation is enabled in the Kakao app.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:4177/api/auth/kakao/callback/

# Naver Login credentials.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:4177/api/auth/naver/callback/

# Use a long random value, at least 32 characters.
IYOGAU_SESSION_SECRET=replace-with-at-least-32-random-characters

# Direct email/password accounts use the same storage as saved birth profiles.
# In production/preview, configure Upstash below before enabling public signup.

# Optional local profile storage:
# - If omitted locally, the dev server stores profiles in .data/profile-store.json.
# - Required on Vercel preview/production for durable profile storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to 0 to disable the local development test account.
# When real Google OAuth is configured, the UI uses Google sign-in.
IYOGAU_ENABLE_DEV_AUTH=0
